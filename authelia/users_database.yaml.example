# Authelia users database - EXAMPLE
# Copy to users_database.yaml and replace with your own users.
# Generate password hashes with: docker compose exec authelia authelia crypto hash generate argon2 --password 'yourpassword'

users:
  example:
    displayname: "Example User"
    password: # Create password hash with "docker compose exec authelia authelia crypto hash generate argon2 --password 'yourpassword'"
    email: user@example.com
    groups:
      - admins
